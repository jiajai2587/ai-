{
  "manifest_version": 3,
  "name": "文章同步助手",
  "version": "1.0.0",
  "description": "一键批量发布文章到知乎、掘金、头条、CSDN、简书、微博、小红书、抖音等 29+ 自媒体平台，支持网页转 Markdown、自建站发布、智能提取、AI 优化等功能",
  "author": "ArticleSync",
  "homepage_url": "https://github.com/jiajai2587/ai-",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "文章同步助手"
  },

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "downloads",
    "alarms",
    "notifications",
    "clipboardWrite",
    "clipboardRead",
    "contextMenus",
    "scripting"
  ],

  "optional_permissions": [
    "aiLanguageModel"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "options_page": "options/options.html",

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "打开文章同步助手"
    },
    "extract_content": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "提取当前页面内容"
    }
  },

  "web_accessible_resources": [
    {
      "resources": [
        "lib/*",
        "icons/*",
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
